# انسخ هذا الملف إلى .env واملأ القيم الحقيقية

# رابط اتصال MongoDB Atlas — احصل عليه من لوحة Atlas (Connect > Drivers)
# مثال: mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/school?retryWrites=true&w=majority
MONGODB_URI=

# مفتاح سرّي لتوقيع رموز الدخول (اكتب نصّاً عشوائياً طويلاً)
JWT_SECRET=ضع_نصّاً_عشوائياً_طويلاً_هنا

# بيانات حساب المدير الافتراضي (تُستخدم عند تشغيل seed)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=1234

# المنفذ (Cloud Run يحدّده تلقائياً)
PORT=8080
